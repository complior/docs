{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Complior",
  "colors": {
    "primary": "#1A56DB",
    "light": "#3B82F6",
    "dark": "#1E293B"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/complior/complior"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/getting-started/quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "installation",
              "getting-started/quickstart",
              "getting-started/first-scan",
              "getting-started/first-passport",
              "getting-started/first-fix"
            ]
          },
          {
            "group": "Scan (Static Analysis)",
            "pages": [
              "scan/overview",
              "scan/scan-tiers",
              "scan/scoring",
              "scan/ci-cd"
            ]
          },
          {
            "group": "Eval (Dynamic Testing)",
            "pages": [
              "eval/overview",
              "eval/eval-modes",
              "eval/conformity-tests",
              "eval/security-probes",
              "eval/eval-vs-scan"
            ]
          },
          {
            "group": "Fix (Auto-Remediation)",
            "pages": [
              "fix/overview",
              "fix/fix-strategies",
              "fix/document-generation",
              "fix/llm-enrichment"
            ]
          },
          {
            "group": "Agent Passport",
            "pages": [
              "passport/overview",
              "passport/passport-modes",
              "passport/data-pipeline",
              "passport/autonomy-levels",
              "passport/risk-classification",
              "passport/evidence-chain",
              "passport/export-formats"
            ]
          },
          {
            "group": "Compliance Documents",
            "pages": [
              "compliance-docs/overview",
              "compliance-docs/fria",
              "compliance-docs/ai-policy",
              "compliance-docs/audit-package"
            ]
          },
          {
            "group": "SDK (Runtime)",
            "pages": [
              "sdk/overview",
              "sdk/quick-start",
              "sdk/hooks",
              "sdk/providers"
            ]
          },
          {
            "group": "MCP Server",
            "pages": [
              "mcp/overview",
              "mcp/setup"
            ]
          },
          {
            "group": "Standards",
            "pages": [
              "standards/eu-ai-act",
              "standards/iso-42001",
              "standards/frameworks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/complior/complior",
          "icon": "github"
        },
        {
          "anchor": "Community",
          "href": "https://discord.gg/complior",
          "icon": "discord"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/complior",
      "github": "https://github.com/complior",
      "linkedin": "https://linkedin.com/company/complior"
    }
  }
}
